#!/usr/bin/env python3
"""Generate blog cover images using Gemini with a consistent character reference.

Reads prompts from {{ .image_gen.prompts_file }} (relative to blog root).

Usage:
    ./scripts/generate-images.py --reference {{ .metaphor.reference_image }}
    ./scripts/generate-images.py --reference <ref.png> --only <key>[,<key>...]
    ./scripts/generate-images.py --reference <ref.png> --list
    ./scripts/generate-images.py --reference <ref.png> --dry-run

Requires {{ .image_gen.api_key_env }} env var (skipped when BLOG_CRAFT_TEST_MODE=1).
"""

import argparse
import os
import sys
import time
from pathlib import Path

import yaml

MODEL = "{{ .image_gen.model }}"
API_KEY_ENV = "{{ .image_gen.api_key_env }}"
BLOG_ROOT = Path(__file__).resolve().parent.parent
PROMPTS_FILE = BLOG_ROOT / "{{ .image_gen.prompts_file }}"
TEST_MODE = os.environ.get("BLOG_CRAFT_TEST_MODE") == "1"

# Hardcoded 1x1 black PNG (67 bytes). Used by TEST_MODE to avoid pulling in Pillow.
_TINY_PNG = bytes.fromhex(
    "89504e470d0a1a0a0000000d49484452000000010000000108020000009077"
    "53de0000000c4944415408d763606000000004000139c8a4660000000049454e44ae426082"
)


def load_prompts(path: Path) -> dict:
    with open(path) as f:
        return yaml.safe_load(f)


def post_process(source_path: Path, steps: list) -> None:
    """Run post-processing steps: resize, crop_resize, or ICO conversion."""
    from PIL import Image  # lazy: only needed for real generation
    img = Image.open(source_path)

    for step in steps:
        if "crop_resize" in step:
            cfg = step["crop_resize"]
            target = BLOG_ROOT / cfg["target"]
            tw, th = cfg["width"], cfg["height"]
            gravity = cfg.get("gravity", 0.5)
            target_ratio = tw / th
            src_w, src_h = img.size
            src_ratio = src_w / src_h

            if src_ratio > target_ratio:
                new_w = int(src_h * target_ratio)
                left = int((src_w - new_w) * gravity)
                cropped = img.crop((left, 0, left + new_w, src_h))
            else:
                new_h = int(src_w / target_ratio)
                top = int((src_h - new_h) * gravity)
                cropped = img.crop((0, top, src_w, top + new_h))

            resized = cropped.resize((tw, th), Image.LANCZOS)
            target.parent.mkdir(parents=True, exist_ok=True)
            resized.save(str(target))
            print(f"    Crop+Resize -> {target.relative_to(BLOG_ROOT)} ({tw}x{th})")
            img = resized

        elif "resize" in step:
            cfg = step["resize"]
            target = BLOG_ROOT / cfg["target"]
            width = cfg.get("width")
            height = cfg.get("height")
            size = cfg.get("size")
            if size:
                width, height = size, size
            resized = img.resize((width, height), Image.LANCZOS)
            target.parent.mkdir(parents=True, exist_ok=True)
            resized.save(str(target))
            print(f"    Resized -> {target.relative_to(BLOG_ROOT)} ({width}x{height})")

        elif "ico" in step:
            cfg = step["ico"]
            target = BLOG_ROOT / cfg["target"]
            size = cfg["size"]
            ico_img = img.resize((size, size), Image.LANCZOS)
            target.parent.mkdir(parents=True, exist_ok=True)
            ico_img.save(str(target), format="ICO", sizes=[(size, size)])
            print(f"    ICO     -> {target.relative_to(BLOG_ROOT)} ({size}x{size})")


def write_test_image(output_path: Path) -> bool:
    """In test mode, write a 1x1 PNG instead of calling the API. No PIL needed."""
    output_path.parent.mkdir(parents=True, exist_ok=True)
    output_path.write_bytes(_TINY_PNG)
    print(f"  [TEST_MODE] Wrote 1px PNG: {output_path.relative_to(BLOG_ROOT)}")
    return True


def generate_one(client, reference, key, output_path, prompt,
                 base_style, reference_guidance, model=MODEL,
                 aspect_ratio=None, image_size=None) -> bool:
    full_prompt = f"{base_style}\n\n{reference_guidance}\n\n{prompt}"

    print(f"\n{'='*60}")
    print(f"  [{key}] -> {output_path.relative_to(BLOG_ROOT)}")
    print(f"{'='*60}")
    if aspect_ratio or image_size:
        print(f"  Image config: aspect_ratio={aspect_ratio}, image_size={image_size}")
    print(f"  Prompt: {prompt[:80]}...")

    if TEST_MODE:
        return write_test_image(output_path)

    print("  Generating...", flush=True)
    try:
        gen_config = None
        if aspect_ratio or image_size:
            from google import genai
            image_config_kwargs = {}
            if aspect_ratio:
                image_config_kwargs["aspect_ratio"] = aspect_ratio
            if image_size:
                image_config_kwargs["image_size"] = image_size
            gen_config = genai.types.GenerateContentConfig(
                image_config=genai.types.ImageConfig(**image_config_kwargs),
            )

        response = client.models.generate_content(
            model=model,
            contents=[full_prompt, reference],
            config=gen_config,
        )

        for part in response.parts:
            if part.inline_data is not None:
                image = part.as_image()
                output_path.parent.mkdir(parents=True, exist_ok=True)
                image.save(str(output_path))
                print(f"  Saved: {output_path.relative_to(BLOG_ROOT)}")
                return True
            elif part.text is not None:
                print(f"  Model text: {part.text[:200]}", file=sys.stderr)

        print("  FAILED: No image in response", file=sys.stderr)
        return False

    except Exception as e:
        print(f"  ERROR: {e}", file=sys.stderr)
        return False


def main() -> None:
    config = load_prompts(PROMPTS_FILE)
    base_style = config["base_style"]
    reference_guidance = config["reference_guidance"]
    images = config["images"]

    all_keys = [img["key"] for img in images]

    parser = argparse.ArgumentParser(
        description="Generate blog cover images with a consistent character reference"
    )
    parser.add_argument("--reference", "-r", help="Path to the master reference image (required unless TEST_MODE)")
    parser.add_argument("--only", help="Comma-separated list of image keys to generate (default: all)")
    parser.add_argument("--list", action="store_true", help="List all image keys and exit")
    parser.add_argument("--dry-run", action="store_true", help="Show what would be generated without calling the API")
    parser.add_argument("--model", "-m", default=MODEL, help=f"Gemini model (default: {MODEL})")
    parser.add_argument("--delay", type=int, default=5, help="Seconds between API calls (default: 5)")
    args = parser.parse_args()

    if args.list:
        print("Available image keys:")
        for img in images:
            desc = img.get("description", "")
            print(f"  {img['key']:20s} -> {img['output']}  ({desc})")
        return

    if args.only:
        selected = set(args.only.split(","))
        unknown = selected - set(all_keys)
        if unknown:
            print(f"Error: Unknown keys: {', '.join(unknown)}", file=sys.stderr)
            print(f"Valid keys: {', '.join(all_keys)}", file=sys.stderr)
            sys.exit(1)
        targets = [img for img in images if img["key"] in selected]
    else:
        targets = images

    if args.dry_run:
        print(f"Dry run -- would generate {len(targets)} images:\n")
        for img in targets:
            has_pp = " [+post-process]" if img.get("post_process") else ""
            print(f"  {img['key']:20s} -> {img['output']}{has_pp}")
        return

    client = None
    reference = None
    if not TEST_MODE:
        api_key = os.environ.get(API_KEY_ENV)
        if not api_key:
            print(f"Error: {API_KEY_ENV} environment variable is required", file=sys.stderr)
            sys.exit(1)
        if not args.reference:
            print("Error: --reference is required (omit only when BLOG_CRAFT_TEST_MODE=1)", file=sys.stderr)
            sys.exit(1)
        from google import genai
        from PIL import Image
        client = genai.Client(api_key=api_key)
        reference = Image.open(args.reference)
        print(f"Model: {args.model}")
        print(f"Reference: {args.reference}")
    else:
        print(f"[TEST_MODE] Skipping API client + reference image; will write 1px PNGs.")

    print(f"Prompts: {PROMPTS_FILE.relative_to(BLOG_ROOT)}")
    print(f"Generating {len(targets)} images...")

    succeeded = 0
    failed = []

    for i, img in enumerate(targets):
        key = img["key"]
        output_path = BLOG_ROOT / img["output"]
        prompt = img["prompt"]

        ok = generate_one(
            client, reference, key, output_path, prompt,
            base_style, reference_guidance, model=args.model,
            aspect_ratio=img.get("aspect_ratio"),
            image_size=img.get("image_size"),
        )
        if ok:
            succeeded += 1
            if img.get("post_process"):
                print(f"  Post-processing {key}...")
                post_process(output_path, img["post_process"])
        else:
            failed.append(key)

        if not TEST_MODE and i < len(targets) - 1:
            print(f"  Waiting {args.delay}s before next request...")
            time.sleep(args.delay)

    print(f"\n{'='*60}")
    print(f"  Done: {succeeded}/{len(targets)} succeeded")
    if failed:
        print(f"  Failed: {', '.join(failed)}")
        print(f"\n  Retry failed with: --only {','.join(failed)}")
    print(f"{'='*60}")

    sys.exit(1 if failed else 0)


if __name__ == "__main__":
    main()
