base_style: |
{{ indent 2 .metaphor.base_style }}

reference_guidance: |
{{ indent 2 .metaphor.reference_guidance }}

images:
  # ──────────────────────────────────────────────────────────────────────────────
  # TILES — script-generated, 16:9.
  # Each tile serves as both the homepage series card AND the overview post cover
  # (same file referenced from two contexts).
  # ──────────────────────────────────────────────────────────────────────────────
  - key: tile-landing
    output: {{ .image_gen.output_dir }}/tile-landing.png
    aspect_ratio: "16:9"
    description: "Homepage hero tile for the {{ .project.name }} root page (16:9)"
    prompt: ""    # fill in: establish the blog's visual world — the institution itself, not a specific scene
{{- range .series }}
  - key: tile-{{ .key }}
    output: {{ $.image_gen.output_dir }}/tile-{{ .key }}.png
    aspect_ratio: "16:9"
    description: "Homepage card tile and overview cover for the {{ .title }} track (16:9)"
    prompt: ""    # fill in: evoke the {{ .title }} domain; same image used as homepage card and overview cover
{{- end }}

  # ──────────────────────────────────────────────────────────────────────────────
  # BANNERS — OPERATOR-GENERATED. Target size: 1200×200 px (6:1 ratio).
  # Gemini API does not support panoramic aspect ratios (only 1:1, 4:3, 3:4, 16:9, 9:16),
  # so banners cannot be generated by scripts/generate-images.py. Generate each banner
  # manually via the Gemini web interface, then drop the PNG into {{ .image_gen.output_dir }}/.
  # The entries below carry the prompts and metadata for reference; do NOT run them
  # through generate-images.py — the API call will fail.
  # ──────────────────────────────────────────────────────────────────────────────

  # OPERATOR-GENERATED via Gemini web. Do not run through generate-images.py.
  - key: banner-landing
    output: {{ .image_gen.output_dir }}/banner-landing.png
    aspect_ratio: "6:1"
    description: "Thin panoramic header banner for the {{ .project.name }} homepage (6:1, 1200×200)"
    prompt: ""    # fill in: thin panoramic establishing view that reads well as a horizontal strip
{{- range .series }}

  # OPERATOR-GENERATED via Gemini web. Do not run through generate-images.py.
  - key: banner-{{ .key }}
    output: {{ $.image_gen.output_dir }}/banner-{{ .key }}.png
    aspect_ratio: "6:1"
    description: "Thin panoramic header banner for the {{ .title }} section (6:1, 1200×200)"
    prompt: ""    # fill in: thin panoramic view of the {{ .title }} domain that reads well as a horizontal strip
{{- end }}
