# Per-image entries. Composition (base_style/persona/layers/order) lives in
# .blog-craft.yaml (image.composition_order + image.layers); scripts/generate-images.py
# composes each prompt from those layers + the entry's `prompt` (the scene) and
# per-image selectors (series, torso_variant, mood). See docs/CONFIG.md §4.1.
images:
  # ──────────────────────────────────────────────────────────────────────────────
  # TILES — script-generated, 16:9. Each tile is both the homepage series card AND
  # the overview post cover.
  # ──────────────────────────────────────────────────────────────────────────────
  - key: tile-landing
    series: generic
    output: {{ .image.output_dir }}/tile-landing.png
    aspect_ratio: "16:9"
    description: "Homepage hero tile for the {{ .project.name }} root page (16:9)"
    prompt: ""    # fill in: establish the blog's visual world — the institution itself, not a specific scene
{{- range .series }}
  - key: tile-{{ .key }}
    series: {{ .key }}
    output: {{ $.image.output_dir }}/tile-{{ .key }}.png
    aspect_ratio: "16:9"
    description: "Homepage card tile and overview cover for the {{ .title }} track (16:9)"
    prompt: ""    # fill in: evoke the {{ .title }} domain; same image used as homepage card and overview cover
{{- end }}

  # ──────────────────────────────────────────────────────────────────────────────
  # BANNERS — OPERATOR-GENERATED (operator_generated: true → generate-images.py skips them).
  # Gemini API does not support panoramic 6:1; generate via the Gemini web UI (1200×200)
  # and drop the PNG into {{ .image.output_dir }}/.
  # ──────────────────────────────────────────────────────────────────────────────
  - key: banner-landing
    output: {{ .image.output_dir }}/banner-landing.png
    aspect_ratio: "6:1"
    operator_generated: true
    description: "Thin panoramic header banner for the {{ .project.name }} homepage (6:1, 1200×200)"
    prompt: ""    # fill in: thin panoramic establishing view that reads well as a horizontal strip
{{- range .series }}
  - key: banner-{{ .key }}
    output: {{ $.image.output_dir }}/banner-{{ .key }}.png
    aspect_ratio: "6:1"
    operator_generated: true
    description: "Thin panoramic header banner for the {{ .title }} section (6:1, 1200×200)"
    prompt: ""    # fill in: thin panoramic view of the {{ .title }} domain that reads well as a horizontal strip
{{- end }}
