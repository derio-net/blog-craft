version: 2
{{- if .blog_craft_version }}
blog_craft_version: {{ .blog_craft_version | quote }}
{{- end }}

project:
{{ toYaml .project | indent 2 }}

# Image composition — config-declared order (see docs/CONFIG.md §4.1).
# The generator concatenates `composition_order` layers; each layer in `layers`
# is a scalar (verbatim), a list ("- " bullets), or an indexed-table (torso/mood,
# selected per-image). `scene` is reserved -> the per-image entry's `prompt`.
image:
{{ toYaml .image | indent 2 }}

series:
{{ toYaml .series }}
{{- if .content_types }}

# Opt-in content types (e.g. papers). Absent => not materialized.
content_types:
{{ toYaml .content_types | indent 2 }}
{{- end }}
{{- if .quality }}

# Post-quality gate — educational-writing methodology (see docs/CONFIG.md §7).
# Governs scripts/validate_educational.py. When enabled, the shipped CI wires the
# gate on every `content_type: posts` post. Absent => gate not wired.
quality:
{{ toYaml .quality | indent 2 }}
{{- end }}

features:
{{ toYaml .features | indent 2 }}

voice: |
{{ indent 2 .voice }}

ci:
{{ toYaml .ci | indent 2 }}
