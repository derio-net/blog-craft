name: blog
on:
  push:
    branches: [main]
  pull_request:

jobs:
  validate:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: peaceiris/actions-hugo@v3
        with:
          hugo-version: '0.157.0'
          extended: true
      - name: Install deps
        run: python3 -m pip install --quiet pyyaml
{{- with .content_types }}{{- with .papers }}
      # Papers content-type present -> sync data, then validate dossiers + frontmatter.
      # Validators ship into the blog at scripts/ (mirrored from blog-craft tools/),
      # so a plain-python CI runs them without the plugin.
      - name: Validate papers
        run: |
          python3 scripts/sync_dossier_to_data.py --config .blog-craft.yaml --check
          for d in {{ .dossier_dir }}/*/dossier.md; do
            python3 scripts/validate_dossier.py --config .blog-craft.yaml "$d"
          done
          python3 scripts/validate_papers.py --config .blog-craft.yaml content/docs/*/*/index.md
{{- end }}{{- end }}
{{- with .quality }}{{- if .enabled }}
      # Educational-writing gate: every `content_type: posts` post must carry the
      # evidence a genuinely useful teaching post needs (reader_goal, Diátaxis
      # mode, a command/output block, an actionable section). Papers/explainers
      # are skipped — they have their own validators. Ships at scripts/ so a
      # plain-python CI runs it without the plugin.
      - name: Validate post quality (educational-writing)
        run: python3 scripts/validate_educational.py --config .blog-craft.yaml content/docs/*/*/index.md
{{- end }}{{- end }}
      # Mermaid syntax gate: lint every ```mermaid fence (posts, explainers,
      # papers) before render so a broken diagram fails CI instead of shipping
      # dead. On by default; opt out with `quality.mermaid_syntax: false`. Ships
      # at scripts/ (mirrored from blog-craft tools/) for plugin-free CI.
      - name: Validate mermaid syntax
        run: python3 scripts/validate_mermaid.py --config .blog-craft.yaml content/docs/*/*/index.md
      - name: Hugo build
        run: hugo --minify
{{- with .ci }}
{{- if eq .deploy.kind "pages" }}

  deploy:
    needs: validate
    runs-on: ubuntu-latest
    steps:
      - run: echo "Deploy via GitHub Pages — wire actions/upload-pages-artifact + actions/deploy-pages."
{{- else if eq .deploy.kind "container_pages" }}

  deploy:
    needs: validate
    runs-on: ubuntu-latest
    steps:
      - run: echo "Build a container image + publish — wire your registry + cluster manifest bump."
{{- end }}
{{- end }}
